# ===== AI 멀티에이전트 (Anthropic Claude) =====
# 실제 값은 커밋하지 않는다 (ai-env security.md / SEC-01).
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 에이전트가 사용할 기본 모델 (최신 Claude 권장)
SAM2_AGENT_MODEL=claude-opus-4-8
# 가벼운 판단(성격/대사 등)에 쓸 경량 모델
SAM2_AGENT_MODEL_LIGHT=claude-haiku-4-5-20251001

# 에이전트 호출 상한 (비용 가드레일)
SAM2_AGENT_MAX_TOKENS=2048
SAM2_AGENT_TURN_TIMEOUT_MS=30000

# ===== 서버 (에이전트 호출을 프록시하는 API; 키를 브라우저에 노출하지 않음) =====
SAM2_SERVER_PORT=8787
