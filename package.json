{
  "name": "new-sam2",
  "version": "0.1.0",
  "private": true,
  "description": "KOEI 삼국지2(Romance of the Three Kingdoms II) 웹 리뉴얼 - AI 멀티에이전트 기반",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @sam2/web dev",
    "data:build": "node scripts/data/build-cities.mjs",
    "data:validate": "node scripts/data/validate.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm data:validate && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
